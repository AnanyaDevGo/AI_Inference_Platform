:80 {
    log {
        output stdout
    }

    # Serve static frontend files
    root * /srv

    route {
        @api_paths {
            path /api/* /admin/* /auth/* /v1/* /health* /docs* /openapi.json* /redoc*
        }
        reverse_proxy @api_paths {$API_HOST:http://api:8000} {
            header_up X-Request-ID {uuid}
        }

        try_files {path} /index.html
        file_server
    }
}

