# =============================================================================
# AI Inference Platform — Environment Configuration
# Copy to .env and fill in required values before starting.
# NEVER commit .env to version control.
# =============================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING

# PostgreSQL connection string (matches docker-compose.yml db service)
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@db:5432/inference_platform

# Redis connection string (matches docker-compose.yml redis service)
REDIS_URL=redis://redis:6379/0

# Ollama runs natively on host — use host.docker.internal from Docker containers
# Linux: use 172.17.0.1 or host network mode
# macOS/Windows: host.docker.internal works out of the box
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── OPTIONAL (defaults shown) ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# Inference settings
INFERENCE_TIMEOUT_SECONDS=120
INFERENCE_NUM_CTX=2048
OLLAMA_MAX_LOADED_MODELS=1

# Rate limiting
RATE_LIMIT_FAIL_OPEN=true

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Data retention
USAGE_LOG_RETENTION_DAYS=90

# ── DATABASE credentials (used by docker-compose.yml db service) ──────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=inference_platform

# ── SMTP (Email OTP Delivery Configuration) ───────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password

# ── SUPER ADMIN ───────────────────────────────────────────────────────────────
# Default credentials seeded on startup if they do not exist
SUPER_ADMIN_EMAIL=admin@platform.com
SUPER_ADMIN_PASSWORD=password123


