        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Logins/min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "spanNulls": false
