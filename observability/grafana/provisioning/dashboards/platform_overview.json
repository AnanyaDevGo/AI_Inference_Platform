      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "DOWN" } }, "type": "special" },
            { "options": { "from": 1, "result": { "color": "green", "text": "UP" }, "to": 1 }, "type": "range" },
            { "options": { "from": 0, "result": { "color": "red", "text": "DOWN" }, "to": 0 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
